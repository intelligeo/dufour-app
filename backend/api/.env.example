# Environment variables for Dufour API

# Database Configuration (External alwaysdata.net)
POSTGIS_HOST=postgresql-intelligeo.alwaysdata.net
POSTGIS_PORT=5432
POSTGIS_DB=intelligeo_dufour
POSTGIS_USER=intelligeo_dufour_admin
POSTGIS_PASSWORD=change_me_in_production

# QGIS Server
QGIS_SERVER_URL=http://qgis-server:8080

# Paths
PROJECTS_DIR=/data/projects
QWC_CONFIG_DIR=/qwc-config

# API
API_TITLE=Dufour Middleware API
API_VERSION=1.0.0
